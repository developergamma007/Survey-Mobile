# Local development — Android emulator (10.0.2.2 = host machine localhost)
EXPO_PUBLIC_API_URL=http://10.0.2.2:8002

# Physical device on same Wi‑Fi (replace with your computer's LAN IP)
# EXPO_PUBLIC_API_URL=http://192.168.1.76:8002

# Production APK — use npm run android:apk instead of setting this manually
# EXPO_PUBLIC_API_URL=https://peoplepulse.iswot.in

# Ward for this build (read-only on survey form). Match website ?ward= link value.
# EXPO_PUBLIC_WARD_NAME=1 - K Narayanapura
